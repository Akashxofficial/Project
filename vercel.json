{
  "installCommand": "npm install --legacy-peer-deps",
  "crons": [
    {
      "path": "/api/admin/notify",
      "schedule": "0 14 * * *"
    }
  ],
  "rewrites": [
    {
      "source": "/api/track/activity",
      "destination": "/api/track.js?type=activity"
    },
    {
      "source": "/api/track/user",
      "destination": "/api/track.js?type=user"
    },
    {
      "source": "/api/track/payment",
      "destination": "/api/track.js?type=payment"
    },
    {
      "source": "/api/track/subscription",
      "destination": "/api/track.js?type=subscription"
    },
    {
      "source": "/api/admin/notify/stats",
      "destination": "/api/admin/notify.js?action=stats"
    },
    {
      "source": "/api/admin/notify/streak-reminder",
      "destination": "/api/admin/notify.js?action=streak-reminder"
    },
    {
      "source": "/api/admin/notify/study-reminder",
      "destination": "/api/admin/notify.js?action=study-reminder"
    },
    {
      "source": "/api/admin/notify/cron-reminder",
      "destination": "/api/admin/notify.js?action=cron-reminder"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ],
  "functions": {
    "api/generate.js":              { "maxDuration": 60 },
    "api/razorpay-order.js":        { "maxDuration": 30 },
    "api/razorpay-verify.js":       { "maxDuration": 30 },
    "api/track.js":                 { "maxDuration": 15 },
    "api/admin/activities.js":               { "maxDuration": 30 },
    "api/admin/students.js":                 { "maxDuration": 30 },
    "api/admin/approve-subscription.js":     { "maxDuration": 30 },
    "api/admin/reject-subscription.js":      { "maxDuration": 30 },
    "api/notify/welcome.js":              { "maxDuration": 15 },
    "api/admin/broadcast.js":             { "maxDuration": 60 },
    "api/admin/notify.js":                 { "maxDuration": 60 }
  }
}